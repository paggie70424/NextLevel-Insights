# Whoop API Credentials
# Get these from https://developer.whoop.com
WHOOP_CLIENT_ID=your_whoop_client_id_here
WHOOP_CLIENT_SECRET=your_whoop_client_secret_here
WHOOP_REDIRECT_URI=http://localhost:3001/api/auth/whoop/callback

# Sign in with Apple (optional)
# VITE_APPLE_CLIENT_ID=com.yourapp.service
# VITE_APPLE_REDIRECT_URI=http://localhost:3001/api/auth/apple/callback

# AWS Configuration (loaded from ~/.aws/credentials by default)
# AWS_REGION=ap-southeast-2
# AWS_PROFILE=c3l-analytics
# NLI_S3_BUCKET=your-s3-bucket-name
